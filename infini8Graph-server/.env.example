# =============================================================================
# Infini8Graph — Server Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# Server Configuration
# -----------------------------------------------------------------------------
PORT=3005
NODE_ENV=development                  # development | production

# -----------------------------------------------------------------------------
# JWT Configuration
# Generate a strong secret: openssl rand -hex 64
# -----------------------------------------------------------------------------
JWT_SECRET=your_super_secret_jwt_key_min_64_chars_hex
JWT_EXPIRES_IN=7d

# -----------------------------------------------------------------------------
# Encryption Key
# Used to encrypt/decrypt Meta & Google OAuth tokens stored in Supabase.
# Must be exactly 32 characters.
# Generate: openssl rand -hex 16
# -----------------------------------------------------------------------------
ENCRYPTION_KEY=your_32_character_encryption_key_here

# -----------------------------------------------------------------------------
# Meta / Facebook / Instagram OAuth
# Create an app at: https://developers.facebook.com/
# -----------------------------------------------------------------------------
META_APP_ID=your_meta_app_id
META_APP_SECRET=your_meta_app_secret
META_REDIRECT_URI=https://your-server-domain/api/auth/callback
META_GRAPH_API_VERSION=v18.0

# -----------------------------------------------------------------------------
# Supabase
# Find these in your Supabase project: Settings → API
# Use the SERVICE ROLE key (not the anon key) for server-side operations.
# -----------------------------------------------------------------------------
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_KEY=your_supabase_service_role_key

# -----------------------------------------------------------------------------
# Frontend URLs
# Used for CORS policy and OAuth redirect targets.
# -----------------------------------------------------------------------------
FRONTEND_URL=http://localhost:3000
FRONTEND_REDIRECT_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# Cache TTL (seconds)
# Controls how long Instagram data is cached in memory before re-fetching.
# -----------------------------------------------------------------------------
CACHE_TTL_OVERVIEW=300
CACHE_TTL_GROWTH=600
CACHE_TTL_POSTS=300
CACHE_TTL_REELS=300

# -----------------------------------------------------------------------------
# Webhook Configuration (Instagram Auto-Reply)
# Set this token in Meta App Dashboard → Webhooks → Verify Token.
# -----------------------------------------------------------------------------
WEBHOOK_VERIFY_TOKEN=your_custom_webhook_verify_token

# -----------------------------------------------------------------------------
# Google Ads OAuth
# Create OAuth credentials at: https://console.cloud.google.com/
# Enable the Google Ads API and get a Developer Token from:
# https://ads.google.com/aw/apicenter
# -----------------------------------------------------------------------------
GOOGLE_CLIENT_ID=your_google_oauth_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_oauth_client_secret
GOOGLE_DEVELOPER_TOKEN=your_google_ads_developer_token
GOOGLE_REDIRECT_URL=https://your-server-domain/api/google/auth/callback
